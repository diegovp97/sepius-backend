{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Sepius": "Debug"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": "*",
  "TwitchApi": {
    "ClientId": "",
    "ClientSecret": "",
    "TokenEndpoint": "https://id.twitch.tv/oauth2/token",
    "ApiBaseUrl": "https://api.twitch.tv/helix"
  },
  "Streamlink": {
    "OutputPath": "/recordings",
    "Quality": "best",
    "ExecutablePath": "streamlink",
    "YtDlpPath": "yt-dlp",
    "TwitchCookiesPath": "/run/secrets/sepius/twitch-cookies.txt",
    "YtDlpTranscodeHeight": 720,
    "AdditionalArgs": "--no-config --twitch-supported-codecs=h264,h265,av1 --stream-sorting-excludes '>1080p' --hls-live-restart --retry-streams 5 --retry-max 3"
  },
  "Monitor": {
    "PollingIntervalSeconds": 120,
    "Channels": ["elttblue", "kick:elttblue"]
  },
  "YouTube": {
    "Enabled": false,
    "ClientSecretsPath": "client_secrets.json",
    "TokenStorePath": "youtube_token",
    "PrivacyStatus": "unlisted"
  }
}
