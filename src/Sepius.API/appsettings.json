{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Sepius": "Debug"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": "http://localhost:4200",
  "TwitchApi": {
    "ClientId": "",
    "ClientSecret": "",
    "TokenEndpoint": "https://id.twitch.tv/oauth2/token",
    "ApiBaseUrl": "https://api.twitch.tv/helix"
  },
  "Streamlink": {
    "OutputPath": "/recordings",
    "Quality": "best",
    "ExecutablePath": "streamlink",
    "AdditionalArgs": "--hls-live-restart --retry-streams 5 --retry-max 3"
  },
  "Monitor": {
    "PollingIntervalSeconds": 120,
    "Channels": ["elttblue"]
  },
  "YouTube": {
    "Enabled": false,
    "ClientSecretsPath": "client_secrets.json",
    "TokenStorePath": "youtube_token",
    "PrivacyStatus": "unlisted"
  }
}
